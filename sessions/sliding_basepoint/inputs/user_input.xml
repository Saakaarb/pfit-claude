<?xml version="1.0" ?>
<FIT>
    <EXPERIMENT>
        <FILENAME>
            <E> FILENAME_DATA = force_disp_data_sliding_basepoint.csv </E>
        </FILENAME>
    </EXPERIMENT>


    <MODEL>
        <TRAINABLE_PARAMETERS>
            <P> N_TRAINABLE_PARAMETERS = 5 </P>
        </TRAINABLE_PARAMETERS>
        <TRAINABLE_PARAMETER_DESCRIPTION>
            <PARAM>
                <P> PARAMETER_NAME= c2 </P>
                <P> MIN_VAL=1E4 </P>
                <P> MAX_VAL=1E7 </P>
                <P> LOGSCALE= Y </P>
            </PARAM>
            <PARAM>
                <P> PARAMETER_NAME= Dk </P>
                <P> MIN_VAL=0.1 </P>
                <P> MAX_VAL=10 </P>
                <P> LOGSCALE= Y </P>
            </PARAM>
            <PARAM>
                <P> PARAMETER_NAME= Dc </P>
                <P> MIN_VAL=0.1 </P>
                <P> MAX_VAL=1 </P>
                <P> LOGSCALE= N </P>
            </PARAM>
            <PARAM>
                <P> PARAMETER_NAME= m1 </P>
                <P> MIN_VAL=100 </P>
                <P> MAX_VAL=10000 </P>
                <P> LOGSCALE= Y </P>
            </PARAM>
            <PARAM>
                <P> PARAMETER_NAME= m2 </P>
                <P> MIN_VAL=1 </P>
                <P> MAX_VAL=100 </P>
                <P> LOGSCALE= Y </P>
            </PARAM>
        </TRAINABLE_PARAMETER_DESCRIPTION>
        <FIXED_PARAM_DESCRIPTION>
                <PARAM>
                    <P> NAME = vf </P>
                    <P> VALUE= 0.1 </P>
                </PARAM>
        </FIXED_PARAM_DESCRIPTION>
        <INTEGRATED_SYSTEM_DESCRIPTION>
            <VAR>
                <P> NAME = x1 </P>
                <P> INIT_VAL = 0.0 </P>
            </VAR>
            <VAR>
                <P> NAME = x2 </P>
                <P> INIT_VAL = 0.0 </P>
            </VAR>
            <VAR>
                <P> NAME = v1 </P>
                <P> INIT_VAL = 11.06 </P>
            </VAR>
            <VAR>
                <P> NAME = v2 </P>
                <P> INIT_VAL = 0.0 </P>
            </VAR>
            <VAR>
                <P> NAME = k </P>
                <P> INIT_VAL = 1.29E6 </P>
            </VAR>
            <VAR>
                <P> NAME = c1 </P>
                <P> INIT_VAL = 0.0 </P>
            </VAR>
        </INTEGRATED_SYSTEM_DESCRIPTION>
    </MODEL>
    <POPULATION_OPT>
        <SETTINGS>
            <P> NUM_PARTICLES = 200 </P>
            <P> NUM_ITERS = 20 </P>
            <P> PROCESSORS = 8 </P>
            <P> PSO_STEPSIZE_RTOL = 1E-1,1E-1,1E0,1E0,1E-3,1E-3 </P>
            <P> PSO_STEPSIZE_ATOL = 1E-3,1E-3,1E-1,1E-1,1E1,1E1 </P>
        </SETTINGS>
    </POPULATION_OPT>
    <GRADIENT_OPT>
        <SETTINGS>
            <P> NUM_ITERS = 20 </P>
            <P> STEPSIZE_RTOL = 1e-1,1e-1,1e-0,1e-0,1e-6,1e-5 </P>
            <P> STEPSIZE_ATOL = 1e-3,1e-3,1e-1,1e-1,1e1,1e1 </P>
            <P> INITIAL_TIMESTEP = 1e-5 </P>
            <P> INITIAL_TIME = 0.0 </P>
            <P> MAX_STEPS = 10000 </P>
            <P> INIT_VALUE_LR = 1e-4 </P>
            <P> END_VALUE_LR = 1e-5 </P>
            <P> TRANSITION_STEPS_LR = 2000 </P>
            <P> DECAY_RATE_LR = 0.9 </P>
        </SETTINGS>
    </GRADIENT_OPT>
    <PLOTTING_INFO>
        <P> WRITE_RESULTS = Y </P>
    </PLOTTING_INFO>
</FIT>