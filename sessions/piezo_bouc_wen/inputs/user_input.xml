<?xml version="1.0" ?>
<FIT>
    <EXPERIMENT>
        <FILENAME>
            <E> FILENAME_DATA = correct_units_piezo_electric_actuator.csv </E>
        </FILENAME>
    </EXPERIMENT>
    <MODEL>
        <TRAINABLE_PARAMETERS>
            <P> N_TRAINABLE_PARAMETERS = 6 </P>
        </TRAINABLE_PARAMETERS>
        <TRAINABLE_PARAMETER_DESCRIPTION>
            <PARAM>
                <P> PARAMETER_NAME= alpha </P>
                <P> MIN_VAL=0 </P>
                <P> MAX_VAL=1.0 </P>
                <P> LOGSCALE= N </P>
            </PARAM>
            <PARAM>
                <P> PARAMETER_NAME= beta </P>
                <P> MIN_VAL=0 </P>
                <P> MAX_VAL=0.1 </P>
                <P> LOGSCALE= N </P>
            </PARAM>
            <PARAM>
                <P> PARAMETER_NAME= gamma </P>
                <P> MIN_VAL=0 </P>
                <P> MAX_VAL=0.1 </P>
                <P> LOGSCALE= N </P>
            </PARAM>
            
            <PARAM>
                <P> PARAMETER_NAME= cp </P>
                <P> MIN_VAL=20 </P>
                <P> MAX_VAL=30 </P>
                <P> LOGSCALE= N </P>
            </PARAM>
            <PARAM>
                <P> PARAMETER_NAME= kp </P>
                <P> MIN_VAL=1.0E7 </P>
                <P> MAX_VAL=1.5E7 </P>
                <P> LOGSCALE= Y </P>
            </PARAM>
            <PARAM>
                <P> PARAMETER_NAME= de </P>
                <P> MIN_VAL=1E-7 </P>
                <P> MAX_VAL=1.5E-7 </P>
                <P> LOGSCALE= Y </P>
            </PARAM>
        </TRAINABLE_PARAMETER_DESCRIPTION>
        
        <FIXED_PARAM_DESCRIPTION>
            <PARAM>
                <P> NAME = mp </P>
                <P> VALUE = 0.1 </P>
            </PARAM>
        </FIXED_PARAM_DESCRIPTION>
        <INTEGRATED_SYSTEM_DESCRIPTION>
            <VAR>
                <P> NAME = xp </P>
                <P> INIT_VAL = 0 </P>
            </VAR>
            <VAR>
                <P> NAME = vp </P>
                <P> INIT_VAL = 0 </P>
            </VAR>
            <VAR>
                <P> NAME = h </P>
                <P> INIT_VAL = 0 </P>
            </VAR>
        </INTEGRATED_SYSTEM_DESCRIPTION>
    </MODEL>
    <POPULATION_OPT>
        <SETTINGS>
            <P> NUM_PARTICLES = 200 </P>
            <P> NUM_ITERS = 50 </P>
            <P> PROCESSORS = 8 </P>
            <P> PSO_STEPSIZE_RTOL = 1E0,1E0,1E0 </P>
            <P> PSO_STEPSIZE_ATOL = 1E-3,1E-3,1E-3 </P>
        </SETTINGS>
    </POPULATION_OPT>
    <GRADIENT_OPT>
        <SETTINGS>
            <P> NUM_ITERS = 10 </P>
            <P> STEPSIZE_RTOL = 1E-0,1E-0,1E-0 </P>
            <P> STEPSIZE_ATOL = 1E-8,1E-5,1E-10 </P>
            <P> INITIAL_TIMESTEP = 1e-2 </P>
            <P> INITIAL_TIME = 0 </P>
            <P> MAX_STEPS = 10000 </P>
            <P> INIT_VALUE_LR = 1e-4 </P>
            <P> END_VALUE_LR = 1e-5 </P>
            <P> TRANSITION_STEPS_LR = 500 </P>
            <P> DECAY_RATE_LR = 0.9 </P>
        </SETTINGS>
    </GRADIENT_OPT>
    <PLOTTING_INFO>
        <P> WRITE_RESULTS = Y </P>
    </PLOTTING_INFO>
</FIT>
